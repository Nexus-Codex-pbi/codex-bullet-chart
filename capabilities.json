{
  "dataRoles": [
    {
      "displayName": "Category",
      "name": "category",
      "kind": "Grouping",
      "description": "Row label (e.g. Beat name or Battery code)"
    },
    {
      "displayName": "Actual",
      "name": "actual",
      "kind": "Measure",
      "requiredTypes": [
        {
          "numeric": true
        }
      ],
      "description": "The primary bar value"
    },
    {
      "displayName": "Target",
      "name": "target",
      "kind": "Measure",
      "requiredTypes": [
        {
          "numeric": true
        }
      ],
      "description": "Target marker line"
    },
    {
      "displayName": "Maximum",
      "name": "maximum",
      "kind": "Measure",
      "requiredTypes": [
        {
          "numeric": true
        }
      ],
      "description": "Full scale maximum (optional, auto-calculated if omitted)"
    },
    {
      "displayName": "Sort Order",
      "name": "sortOrder",
      "kind": "Measure",
      "requiredTypes": [
        {
          "numeric": true
        }
      ],
      "description": "Custom sort order (ascending). If omitted, rows keep their original order."
    }
  ],
  "objects": {
