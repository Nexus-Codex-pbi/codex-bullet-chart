{
    "dataRoles": [
        {
            "displayName": "Category",
            "name": "category",
            "kind": "Grouping",
            "description": "Row label (e.g. Beat name or Battery code)"
        },
        {
            "displayName": "Actual",
            "name": "actual",
            "kind": "Measure",
            "requiredTypes": [{ "numeric": true }],
            "description": "The primary bar value"
        },
        {
            "displayName": "Target",
            "name": "target",
            "kind": "Measure",
            "requiredTypes": [{ "numeric": true }],
            "description": "Target marker line"
        },
        {
            "displayName": "Maximum",
            "name": "maximum",
            "kind": "Measure",
            "requiredTypes": [{ "numeric": true }],
            "description": "Full scale maximum (optional, auto-calculated if omitted)"
        }
    ],
    "objects": {
        "bulletSettings": {
            "properties": {
                "orientation": {
                    "type": {
                        "enumeration": [
                            { "displayName": "Horizontal", "value": "horizontal" },
                            { "displayName": "Vertical", "value": "vertical" }
                        ]
                    }
                },
                "barColor": {
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "targetColor": {
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "targetWidth": {
                    "type": { "numeric": true }
                },
                "barHeight": {
                    "type": { "numeric": true }
                },
                "rowHeight": {
                    "type": { "numeric": true }
                },
                "showValue": {
                    "type": { "bool": true }
                },
                "valueFormat": {
                    "type": {
                        "enumeration": [
                            { "displayName": "Number", "value": "number" },
                            { "displayName": "Percent", "value": "percent" },
                            { "displayName": "Currency", "value": "currency" }
                        ]
                    }
                },
                "valueColor": {
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "valueFontSize": {
                    "type": { "numeric": true }
                }
            }
        },
        "qualitativeRanges": {
            "properties": {
                "enabled": {
                    "type": { "bool": true }
                },
                "poorThreshold": {
                    "type": { "numeric": true }
                },
                "acceptableThreshold": {
                    "type": { "numeric": true }
                },
                "poorColor": {
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "acceptableColor": {
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "goodColor": {
                    "type": { "fill": { "solid": { "color": true } } }
                }
            }
        },
        "labelSettings": {
            "properties": {
                "show": {
                    "type": { "bool": true }
                },
                "fontSize": {
                    "type": { "numeric": true }
                },
                "color": {
                    "type": { "fill": { "solid": { "color": true } } }
                }
            }
        }
    },
    "dataViewMappings": [
        {
            "categorical": {
                "categories": {
                    "for": { "in": "category" },
                    "dataReductionAlgorithm": {
                        "top": { "count": 200 }
                    }
                },
                "values": {
                    "select": [
                        { "bind": { "to": "actual" } },
                        { "bind": { "to": "target" } },
                        { "bind": { "to": "maximum" } }
                    ]
                }
            }
        }
    ],
    "supportsHighlight": true,
    "supportsKeyboardFocus": true,
    "supportsLandingPage": true,
    "supportsEmptyDataView": true,
    "supportsMultiVisualSelection": true,
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        },
        "roles": ["tooltips"]
    },
    "privileges": []
}
